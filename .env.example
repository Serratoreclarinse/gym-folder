# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Resend (used server-side only — never expose in client bundle)
# Set these in your Supabase Edge Function secrets, not in the app
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_ADDRESS=GymCoach <noreply@yourdomain.com>

# Supabase webhook secret (set in Supabase dashboard when creating the webhook)
SUPABASE_WEBHOOK_SECRET=your-webhook-secret-string

# App
EXPO_PUBLIC_APP_NAME=Gym Coaching
