{
  "expo": {
    "name": "ELEVATƎ",
    "slug": "gym-coaching-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gymcoaching",
    "userInterfaceStyle": "dark",
    "icon": "./assets/images/logo.png",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jhegroup.elevat3",
      "infoPlist": {
        "NSCameraUsageDescription": "ELEVATƎ uses your camera to scan QR codes and to check your exercise form.",
        "NSMicrophoneUsageDescription": "ELEVATƎ uses the microphone during video-based form checking.",
        "NSPhotoLibraryUsageDescription": "ELEVATƎ reads your photo library to upload progress photos.",
        "NSPhotoLibraryAddUsageDescription": "ELEVATƎ saves progress photos to your photo library.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.jhegroup.elevat3",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logo.png",
          "color": "#0A0A0A",
          "defaultChannel": "sessions"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "db3ebbee-d9d6-4d42-94ce-235f563cdb74"
      }
    },
    "owner": "clarinse",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/db3ebbee-d9d6-4d42-94ce-235f563cdb74"
    }
  }
}
